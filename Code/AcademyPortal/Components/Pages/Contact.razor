@page "/contact"

<PageTitle>Contact — AcademyPortal</PageTitle>

<div class="page-header">
    <h1>📬 Contact Us</h1>
    <p>We would love to hear from you — reach out anytime</p>
</div>

<div class="section-wrapper">
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px; max-width:900px; margin:0 auto;">

        <!-- CONTACT INFO -->
        <div>
            <div class="section-heading">Get In Touch</div>
            <div class="section-title" style="font-size:20px;">We are here to help</div>
            <p style="color:var(--text-muted); font-size:14px; line-height:1.8; margin-bottom:28px;">
                Have questions about enrollment, subjects, or fees?
                Our team is available to assist you every day.
            </p>

            <div style="display:flex; flex-direction:column; gap:16px;">
                <div class="feature-card" style="display:flex; align-items:center; gap:16px; padding:16px;">
                    <div class="card-icon" style="margin:0; flex-shrink:0;">📧</div>
                    <div>
                        <div class="card-title" style="margin-bottom:2px;">Email</div>
                        <div class="card-desc">info@academyportal.com</div>
                    </div>
                </div>
                <div class="feature-card" style="display:flex; align-items:center; gap:16px; padding:16px;">
                    <div class="card-icon" style="margin:0; flex-shrink:0;">📱</div>
                    <div>
                        <div class="card-title" style="margin-bottom:2px;">WhatsApp</div>
                        <div class="card-desc">+92 300 1234567</div>
                    </div>
                </div>
                <div class="feature-card" style="display:flex; align-items:center; gap:16px; padding:16px;">
                    <div class="card-icon" style="margin:0; flex-shrink:0;">🕐</div>
                    <div>
                        <div class="card-title" style="margin-bottom:2px;">Working Hours</div>
                        <div class="card-desc">Mon – Sat: 9am to 9pm PKT</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- CONTACT FORM -->
        <div class="form-wrapper" style="margin:0;">
            <div class="form-title">Send a Message</div>
            <div class="form-subtitle">We will reply within 24 hours</div>

            @if (isSent)
            {
                <div class="alert-success">
                    ✅ Message sent! We will get back to you soon.
                </div>
            }
            else
            {
                <div class="form-group" style="margin-bottom:16px;">
                    <label>Your Name</label>
                    <input type="text" @bind="name" placeholder="e.g. Fatima Ali" />
                </div>
                <div class="form-group" style="margin-bottom:16px;">
                    <label>Email Address</label>
                    <input type="email" @bind="email" placeholder="email@example.com" />
                </div>
                <div class="form-group" style="margin-bottom:16px;">
                    <label>Message</label>
                    <textarea @bind="message" rows="4"
                              placeholder="Write your message here..."
                                  style="background:var(--bg-secondary); border:0.5px solid var(--border); border-radius:8px; padding:10px 14px; color:var(--text-primary); font-size:14px; outline:none; width:100%; resize:vertical;">
                    </textarea>
                    </div>
                    <button class="btn-rose" style="width:100%;" @onclick="HandleSend">
                        Send Message 📬
                    </button>
                }
            </div>
        </div>
    </div>

@code {
    private string name = "";
    private string email = "";
    private string message = "";
    private bool isSent = false;

    private void HandleSend()
    {
        if (!string.IsNullOrWhiteSpace(name) &&
            !string.IsNullOrWhiteSpace(email) &&
            !string.IsNullOrWhiteSpace(message))
        {
            isSent = true;
        }
    }
}