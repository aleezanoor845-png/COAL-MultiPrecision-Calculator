@page "/admin/notifications"
@using AcademyPortal.Models
@using AcademyPortal.Services
@inject NotificationService NotificationService
@inject StudentService StudentService
@inject TeacherService TeacherService

<PageTitle>Notifications — Admin Panel</PageTitle>

<div style="display:flex; min-height:100vh;">

    <!-- SIDEBAR -->
    <div class="admin-sidebar">
        <div class="admin-logo">🌸 AcademyPortal</div>
        <ul class="admin-menu">
            <li><a href="/admin/dashboard">📊 Dashboard</a></li>
            <li><a href="/admin/students">👨‍🎓 Students</a></li>
            <li><a href="/admin/teachers">👨‍🏫 Teachers</a></li>
            <li><a href="/admin/enrollments">📝 Enrollments</a></li>
            <li><a href="/admin/trials">🎯 Trial Requests</a></li>
            <li><a href="/admin/notifications" class="active">🔔 Notifications</a></li>
            <li><a href="/">🔓 Logout</a></li>
        </ul>
    </div>

    <!-- MAIN CONTENT -->
    <div class="admin-content">
        <div class="admin-header">
            <h1>🔔 Send Notifications</h1>
            <p>Send messages to students, teachers or everyone</p>
        </div>

        @if (isSent)
        {
            <div class="alert-success" style="margin-bottom:24px;">✅ Notification sent successfully!</div>
        }

        <!-- SEND FORM -->
        <div class="form-wrapper" style="margin-bottom:32px;">
            <div class="form-title" style="font-size:18px; margin-bottom:20px;">Send New Notification</div>

            <div class="form-group" style="margin-bottom:16px;">
                <label>Send To</label>
                <select @bind="receiverType" @bind:after="LoadReceivers">
                    <option value="">-- Select Receiver --</option>
                    <option value="All">📢 Everyone (All Students + Teachers)</option>
                    <option value="Student">👨‍🎓 Specific Student</option>
                    <option value="Teacher">👨‍🏫 Specific Teacher</option>
                </select>
            </div>

            @if (receiverType == "Student")
            {
                <div class="form-group" style="margin-bottom:16px;">
                    <label>Select Student</label>
                    <select @bind="selectedStudentId">
                        <option value="0">-- Select Student --</option>
                        @foreach (var s in students)
                        {
                            <option value="@s.Id">@s.FullName (@s.RollNumber)</option>
                        }
                    </select>
                </div>
            }

            @if (receiverType == "Teacher")
            {
                <div class="form-group" style="margin-bottom:16px;">
                    <label>Select Teacher</label>
                    <select @bind="selectedTeacherId">
                        <option value="0">-- Select Teacher --</option>
                        @foreach (var t in teachers)
                        {
                            <option value="@t.Id">@t.FullName (@t.Subject)</option>
                        }
                    </select>
                </div>
            }

            <div class="form-group" style="margin-bottom:16px;">
                <label>Notification Title</label>
                <input type="text" @bind="notifTitle" placeholder="e.g. Class Cancelled Today" />
            </div>

            <div class="form-group" style="margin-bottom:16px;">
                <label>Message</label>
                <textarea @bind="notifMessage" rows="4"
                          placeholder="Write your notification message here..."
                              style="background:var(--bg-secondary); border:0.5px solid var(--border); border-radius:8px; padding:10px 14px; color:var(--text-primary); font-size:14px; outline:none; width:100%; resize:vertical;">
                </textarea>
                </div>

                <button class="btn-rose" style="width:100%;" @onclick="SendNotification">
                    Send Notification 🔔
                </button>
            </div>

            <!-- ALL NOTIFICATIONS -->
            <div class="admin-header" style="margin-top:0;">
                <h1 style="font-size:20px;">All Sent Notifications</h1>
            </div>

            @if (allNotifications.Count == 0)
            {
                <div class="feature-card" style="text-align:center; padding:32px;">
                    <div style="font-size:36px; margin-bottom:12px;">📭</div>
                    <div class="card-title">No notifications sent yet</div>
                </div>
            }
            else
            {
                <div style="display:flex; flex-direction:column; gap:12px;">
                    @foreach (var n in allNotifications)
                    {
                        <div class="feature-card">
                            <div style="display:flex; justify-content:space-between; align-items:start;">
                                <div>
                                    <div style="display:flex; align-items:center; gap:8px; margin-bottom:4px;">
                                        <div class="card-title">@n.Title</div>
                                        <span class="@(n.ReceiverType == "All" ? "badge-contacted" : n.ReceiverType == "Student" ? "badge-approved" : "badge-pending")">
                                            @n.ReceiverType
                                        </span>
                                    </div>
                                    <div class="card-desc">@n.Message</div>
                                    <div style="font-size:11px; color:var(--text-muted); margin-top:8px;">
                                        @n.CreatedAt.ToString("dd MMM yyyy — hh:mm tt")
                                    </div>
                                </div>
                                <button class="btn-outline-rose" style="padding:4px 10px; font-size:11px; flex-shrink:0;"
                                        @onclick="() => DeleteNotification(n.Id)">
                                    🗑
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }

        </div>
    </div>

@code {
    private List<StudentUser> students = new();
    private List<TeacherUser> teachers = new();
    private List<Notification> allNotifications = new();

    private string receiverType = "";
    private int selectedStudentId = 0;
    private int selectedTeacherId = 0;
    private string notifTitle = "";
    private string notifMessage = "";
    private bool isSent = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        allNotifications = await NotificationService.GetAllAsync();
    }

    private async Task LoadReceivers()
    {
        if (receiverType == "Student")
            students = await StudentService.GetAllAsync();
        else if (receiverType == "Teacher")
            teachers = await TeacherService.GetAllAsync();
    }

    private async Task SendNotification()
    {
        if (string.IsNullOrWhiteSpace(notifTitle) || string.IsNullOrWhiteSpace(notifMessage)) return;

        if (receiverType == "All")
        {
            await NotificationService.SendToAllAsync(notifTitle, notifMessage);
        }
        else if (receiverType == "Student" && selectedStudentId > 0)
        {
            await NotificationService.SendToStudentAsync(selectedStudentId, notifTitle, notifMessage);
        }
        else if (receiverType == "Teacher" && selectedTeacherId > 0)
        {
            await NotificationService.SendToTeacherAsync(selectedTeacherId, notifTitle, notifMessage);
        }

        isSent = true;
        notifTitle = "";
        notifMessage = "";
        receiverType = "";
        await LoadData();
    }

    private async Task DeleteNotification(int id)
    {
        await NotificationService.DeleteAsync(id);
        await LoadData();
    }
}