@page "/admin/enrollments"
@using AcademyPortal.Models
@using AcademyPortal.Services
@inject EnrollmentService EnrollmentService
@inject NavigationManager Navigation

<PageTitle>Enrollments — Admin Panel</PageTitle>

<div style="display:flex; min-height:100vh;">

    <!-- SIDEBAR -->
    <div class="admin-sidebar">
        <div class="admin-logo">🌸 AcademyPortal</div>
        <ul class="admin-menu">
            <li><a href="/admin/dashboard">📊 Dashboard</a></li>
            <li><a href="/admin/students">👨‍🎓 Students</a></li>
            <li><a href="/admin/teachers">👨‍🏫 Teachers</a></li>
            <li><a href="/admin/enrollments" class="active">📝 Enrollments</a></li>
            <li><a href="/admin/trials">🎯 Trial Requests</a></li>
            <li><a href="/admin/notifications">🔔 Notifications</a></li>
            <li><a href="/">🔓 Logout</a></li>
        </ul>
    </div>

    <!-- MAIN CONTENT -->
    <div class="admin-content">
        <div class="admin-header">
            <h1>Enrollments</h1>
            <p>All student enrollment submissions</p>
        </div>

        @if (enrollments == null)
        {
            <p style="color:var(--text-muted);">Loading...</p>
        }
        else if (enrollments.Count == 0)
        {
            <div class="feature-card" style="text-align:center; padding:40px;">
                <div style="font-size:40px; margin-bottom:12px;">📭</div>
                <div class="card-title">No enrollments yet</div>
                <div class="card-desc">Enrollment submissions will appear here.</div>
            </div>
        }
        else
        {
            <div style="background:var(--bg-card); border:0.5px solid var(--border); border-radius:12px; overflow:hidden;">
                <table class="academy-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Student Name</th>
                            <th>Email</th>
                            <th>Semester</th>
                            <th>Subject</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in enrollments)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.StudentName</td>
                                <td>@item.Email</td>
                                <td>@item.Semester</td>
                                <td>@item.Subject</td>
                                <td>
                                    <span class="@(item.Status == "Approved" ? "badge-approved" : "badge-pending")">
                                        @item.Status
                                    </span>
                                </td>
                                <td>@item.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td style="display:flex; gap:6px;">
                                    @if (item.Status != "Approved")
                                    {
                                        <button class="btn-rose" style="padding:4px 10px; font-size:11px;"
                                                @onclick="() => ApproveEnrollment(item.Id)">
                                            ✅ Approve
                                        </button>
                                    }
                                    <button class="btn-outline-rose" style="padding:4px 10px; font-size:11px;"
                                            @onclick="() => DeleteEnrollment(item.Id)">
                                        🗑
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private List<Enrollment>? enrollments;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        enrollments = await EnrollmentService.GetAllAsync();
    }

    private async Task ApproveEnrollment(int id)
    {
        var item = enrollments?.FirstOrDefault(e => e.Id == id);
        if (item != null)
        {
            item.Status = "Approved";
            await LoadData();
        }
    }

    private async Task DeleteEnrollment(int id)
    {
        await EnrollmentService.DeleteAsync(id);
        await LoadData();
    }
}