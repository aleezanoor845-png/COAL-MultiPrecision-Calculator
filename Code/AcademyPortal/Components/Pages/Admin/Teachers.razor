@page "/admin/teachers"
@using AcademyPortal.Models
@using AcademyPortal.Services
@inject TeacherService TeacherService
@inject NotificationService NotificationService

<PageTitle>Teachers — Admin Panel</PageTitle>

<div style="display:flex; min-height:100vh;">

    <!-- SIDEBAR -->
    <div class="admin-sidebar">
        <div class="admin-logo">🌸 AcademyPortal</div>
        <ul class="admin-menu">
            <li><a href="/admin/dashboard">📊 Dashboard</a></li>
            <li><a href="/admin/students">👨‍🎓 Students</a></li>
            <li><a href="/admin/teachers" class="active">👨‍🏫 Teachers</a></li>
            <li><a href="/admin/enrollments">📝 Enrollments</a></li>
            <li><a href="/admin/trials">🎯 Trial Requests</a></li>
            <li><a href="/admin/notifications">🔔 Notifications</a></li>
            <li><a href="/">🔓 Logout</a></li>
        </ul>
    </div>

    <!-- MAIN CONTENT -->
    <div class="admin-content">
        <div class="admin-header">
            <h1>👨‍🏫 Teachers</h1>
            <p>Manage and approve teacher accounts</p>
        </div>

        @if (showNotifForm)
        {
            <div class="form-wrapper" style="margin-bottom:24px;">
                <div class="form-title" style="font-size:16px; margin-bottom:16px;">
                    🔔 Send Notification to @selectedTeacher?.FullName
                </div>
                <div class="form-group" style="margin-bottom:12px;">
                    <label>Title</label>
                    <input type="text" @bind="notifTitle" placeholder="e.g. New Student Enrolled" />
                </div>
                <div class="form-group" style="margin-bottom:12px;">
                    <label>Message</label>
                    <textarea @bind="notifMessage" rows="3"
                              placeholder="Write your message here..."
                                  style="background:var(--bg-secondary); border:0.5px solid var(--border); border-radius:8px; padding:10px 14px; color:var(--text-primary); font-size:14px; outline:none; width:100%; resize:vertical;">
                    </textarea>
                    </div>
                    <div style="display:flex; gap:10px;">
                        <button class="btn-rose" @onclick="SendNotification">Send 🔔</button>
                        <button class="btn-outline-rose" @onclick="() => showNotifForm = false">Cancel</button>
                    </div>
                    @if (notifSent)
                    {
                        <div class="alert-success" style="margin-top:12px;">✅ Notification sent!</div>
                    }
                </div>
            }

            @if (teachers == null)
            {
                <p style="color:var(--text-muted);">Loading...</p>
            }
            else if (teachers.Count == 0)
            {
                <div class="feature-card" style="text-align:center; padding:40px;">
                    <div style="font-size:40px; margin-bottom:12px;">📭</div>
                    <div class="card-title">No teachers registered yet</div>
                </div>
            }
            else
            {
                <div style="background:var(--bg-card); border:0.5px solid var(--border); border-radius:12px; overflow:hidden;">
                    <table class="academy-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Full Name</th>
                                <th>Email</th>
                                <th>Qualification</th>
                                <th>Semester</th>
                                <th>Subject</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in teachers)
                            {
                                <tr>
                                    <td>@t.Id</td>
                                    <td>@t.FullName</td>
                                    <td>@t.Email</td>
                                    <td>@t.Qualification</td>
                                    <td>@t.Semester</td>
                                    <td>@t.Subject</td>
                                    <td>
                                        @if (t.IsApproved)
                                        {
                                            <span class="badge-approved">Approved</span>
                                        }
                                        else
                                        {
                                            <span class="badge-pending">Pending</span>
                                        }
                                    </td>
                                    <td style="display:flex; gap:6px; flex-wrap:wrap;">
                                        @if (!t.IsApproved)
                                        {
                                            <button class="btn-rose" style="padding:4px 10px; font-size:11px;"
                                                    @onclick="() => ApproveTeacher(t.Id)">
                                                ✅ Approve
                                            </button>
                                        }
                                        <button class="btn-outline-rose" style="padding:4px 10px; font-size:11px;"
                                                @onclick="() => OpenNotif(t)">
                                            🔔 Notify
                                        </button>
                                        <button class="btn-outline-rose" style="padding:4px 10px; font-size:11px;"
                                                @onclick="() => DeleteTeacher(t.Id)">
                                            🗑
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

@code {
    private List<TeacherUser>? teachers;
    private TeacherUser? selectedTeacher;
    private bool showNotifForm = false;
    private bool notifSent = false;
    private string notifTitle = "";
    private string notifMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        teachers = await TeacherService.GetAllAsync();
    }

    private void OpenNotif(TeacherUser t)
    {
        selectedTeacher = t;
        showNotifForm = true;
        notifSent = false;
        notifTitle = "";
        notifMessage = "";
    }

    private async Task SendNotification()
    {
        if (string.IsNullOrWhiteSpace(notifTitle) || string.IsNullOrWhiteSpace(notifMessage)) return;
        await NotificationService.SendToTeacherAsync(selectedTeacher!.Id, notifTitle, notifMessage);
        notifSent = true;
    }

    private async Task ApproveTeacher(int id)
    {
        await TeacherService.ApproveAsync(id);
        await LoadData();
    }

    private async Task DeleteTeacher(int id)
    {
        await TeacherService.DeleteAsync(id);
        await LoadData();
    }
}