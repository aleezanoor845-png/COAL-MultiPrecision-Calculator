@page "/admin"
@inject NavigationManager Navigation

<PageTitle>Admin Login — AcademyPortal</PageTitle>

<div style="min-height:100vh; display:flex; align-items:center; justify-content:center; background:var(--bg-primary);">
    <div class="form-wrapper" style="width:100%; max-width:400px;">

        <div style="text-align:center; margin-bottom:28px;">
            <div style="font-size:40px; margin-bottom:12px;">🌸</div>
            <div class="form-title" style="text-align:center;">Admin Login</div>
            <div class="form-subtitle" style="text-align:center;">AcademyPortal Dashboard</div>
        </div>

        @if (isError)
        {
            <div class="alert-danger">
                ❌ Incorrect password. Please try again.
            </div>
        }

        <div class="form-group" style="margin-bottom:16px;">
            <label>Password</label>
            <input type="password"
                   @bind="password"
                   @onkeypress="HandleKeyPress"
                   placeholder="Enter admin password" />
        </div>

        <button class="btn-rose" style="width:100%;" @onclick="HandleLogin">
            Login to Dashboard 🔐
        </button>

        <div style="text-align:center; margin-top:20px;">
            <a href="/" style="color:var(--text-muted); font-size:13px; text-decoration:none;">
                ← Back to Home
            </a>
        </div>
    </div>
</div>

@code {
    private string password = "";
    private bool isError = false;
    private const string AdminPassword = "academy2024";

    private void HandleLogin()
    {
        if (password == AdminPassword)
        {
            Navigation.NavigateTo("/admin/dashboard");
        }
        else
        {
            isError = true;
            password = "";
        }
    }

    private void HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            HandleLogin();
        }
    }
}