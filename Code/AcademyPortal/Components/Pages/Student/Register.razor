@page "/student/register"
@using AcademyPortal.Models
@using AcademyPortal.Services
@inject StudentService StudentService
@inject NavigationManager Navigation

<PageTitle>Student Register — AcademyPortal</PageTitle>

<div style="min-height:100vh; display:flex; align-items:center; justify-content:center; padding:40px 20px;">
    <div class="form-wrapper" style="width:100%; max-width:500px;">

        <div style="text-align:center; margin-bottom:28px;">
            <div style="font-size:48px; margin-bottom:12px;">👨‍🎓</div>
            <div class="form-title" style="text-align:center;">Student Registration</div>
            <div class="form-subtitle" style="text-align:center;">Create your AcademyPortal account</div>
        </div>

        @if (isError)
        {
            <div class="alert-danger">❌ Email already registered. Please use a different email.</div>
        }

        @if (isSuccess)
        {
            <div class="alert-success">
                ✅ Registration successful! Your Roll Number is: <strong>@rollNumber</strong>
                <br />Redirecting to login...
            </div>
        }
        else
        {
            <EditForm Model="student" OnValidSubmit="HandleRegister">
                <DataAnnotationsValidator />

                <div class="form-group" style="margin-bottom:16px;">
                    <label>Full Name</label>
                    <InputText @bind-Value="student.FullName" placeholder="e.g. Hina Naeem" />
                    <ValidationMessage For="@(() => student.FullName)" class="validation-message" />
                </div>

                <div class="form-group" style="margin-bottom:16px;">
                    <label>Email Address</label>
                    <InputText @bind-Value="student.Email" placeholder="242679@students.au.edu.pk" />
                    <ValidationMessage For="@(() => student.Email)" class="validation-message" />
                </div>

                <div class="form-group" style="margin-bottom:16px;">
                    <label>Password</label>
                    <InputText type="password" @bind-Value="student.Password" placeholder="Create a password" />
                    <ValidationMessage For="@(() => student.Password)" class="validation-message" />
                </div>

                <button type="submit" class="btn-rose" style="width:100%; margin-top:8px;">
                    Create Account 🌸
                </button>
            </EditForm>

            <div style="text-align:center; margin-top:20px;">
                <span style="color:var(--text-muted); font-size:13px;">Already have an account? </span>
                <a href="/student/login" style="color:var(--rose-light); font-size:13px;">Login here</a>
            </div>
        }
    </div>
</div>

@code {
    private StudentUser student = new();
    private bool isError = false;
    private bool isSuccess = false;
    private string rollNumber = "";

    private async Task HandleRegister()
    {
        isError = false;
        var result = await StudentService.RegisterAsync(student);
        if (result == null)
        {
            isError = true;
        }
        else
        {
            rollNumber = result.RollNumber;
            isSuccess = true;
            await Task.Delay(3000);
            Navigation.NavigateTo("/student/login");
        }
    }
}