@page "/teacher/register"
@using AcademyPortal.Models
@using AcademyPortal.Services
@inject TeacherService TeacherService
@inject NavigationManager Navigation

<PageTitle>Teacher Register — AcademyPortal</PageTitle>

<div style="min-height:100vh; display:flex; align-items:center; justify-content:center; padding:40px 20px;">
    <div class="form-wrapper" style="width:100%; max-width:500px;">

        <div style="text-align:center; margin-bottom:28px;">
            <div style="font-size:48px; margin-bottom:12px;">👨‍🏫</div>
            <div class="form-title" style="text-align:center;">Teacher Registration</div>
            <div class="form-subtitle" style="text-align:center;">Join AcademyPortal as a Teacher</div>
        </div>

        @if (isError)
        {
            <div class="alert-danger">❌ Email already registered. Please use a different email.</div>
        }

        @if (isSuccess)
        {
            <div class="alert-success">
                ✅ Registration successful! Please wait for admin approval before logging in.
                <br /><br />
                <a href="/" style="color:var(--rose-light);">← Back to Home</a>
            </div>
        }
        else
        {
            <EditForm Model="teacher" OnValidSubmit="HandleRegister">
                <DataAnnotationsValidator />

                <div class="form-group" style="margin-bottom:16px;">
                    <label>Full Name</label>
                    <InputText @bind-Value="teacher.FullName" placeholder="e.g. Dr. Ahmed Khan" />
                    <ValidationMessage For="@(() => teacher.FullName)" class="validation-message" />
                </div>

                <div class="form-group" style="margin-bottom:16px;">
                    <label>Email Address</label>
                    <InputText @bind-Value="teacher.Email" placeholder="teacher@academy.com" />
                    <ValidationMessage For="@(() => teacher.Email)" class="validation-message" />
                </div>

                <div class="form-group" style="margin-bottom:16px;">
                    <label>Password</label>
                    <InputText type="password" @bind-Value="teacher.Password" placeholder="Create a password" />
                    <ValidationMessage For="@(() => teacher.Password)" class="validation-message" />
                </div>

                <div class="form-group" style="margin-bottom:16px;">
                    <label>Qualification</label>
                    <InputSelect @bind-Value="teacher.Qualification">
                        <option value="">-- Select Qualification --</option>
                        <option>BS Computer Science</option>
                        <option>MS Computer Science</option>
                        <option>PhD Computer Science</option>
                        <option>BS Software Engineering</option>
                        <option>MS Software Engineering</option>
                        <option>Other</option>
                    </InputSelect>
                    <ValidationMessage For="@(() => teacher.Qualification)" class="validation-message" />
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Semester</label>
                        <InputSelect @bind-Value="teacher.Semester" @bind-Value:after="LoadSubjects">
                            <option value="">-- Select Semester --</option>
                            <option>Semester 1</option>
                            <option>Semester 2</option>
                            <option>Semester 3</option>
                            <option>Semester 4</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => teacher.Semester)" class="validation-message" />
                    </div>
                    <div class="form-group">
                        <label>Subject</label>
                        <InputSelect @bind-Value="teacher.Subject">
                            <option value="">-- Select Subject --</option>
                            @foreach (var sub in subjectList)
                            {
                                <option>@sub</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => teacher.Subject)" class="validation-message" />
                    </div>
                </div>

                <button type="submit" class="btn-rose" style="width:100%; margin-top:8px;">
                    Submit Registration 👨‍🏫
                </button>
            </EditForm>

            <div style="text-align:center; margin-top:20px;">
                <span style="color:var(--text-muted); font-size:13px;">Already registered? </span>
                <a href="/teacher/login" style="color:var(--rose-light); font-size:13px;">Login here</a>
            </div>
        }
    </div>
</div>

@code {
    private TeacherUser teacher = new();
    private bool isError = false;
    private bool isSuccess = false;
    private List<string> subjectList = new();

    private Dictionary<string, List<string>> semesterSubjects = new()
    {
        ["Semester 1"] = new() { "Introduction to Computing", "Calculus & Analytical Geometry", "English Composition", "Islamic Studies", "Functional English" },
        ["Semester 2"] = new() { "Object Oriented Programming", "Discrete Mathematics", "Digital Logic Design", "Communication Skills", "Pakistan Studies" },
        ["Semester 3"] = new() { "Data Structures & Algorithms", "Database Systems", "Computer Organization", "Linear Algebra", "Probability & Statistics" },
        ["Semester 4"] = new() { "Operating Systems", "Software Engineering", "Computer Networks", "Visual Programming", "Web Technologies" }
    };

    private void LoadSubjects()
    {
        if (!string.IsNullOrEmpty(teacher.Semester) && semesterSubjects.ContainsKey(teacher.Semester))
            subjectList = semesterSubjects[teacher.Semester];
        else
            subjectList = new();
    }

    private async Task HandleRegister()
    {
        isError = false;
        var result = await TeacherService.RegisterAsync(teacher);
        if (result == null)
        {
            isError = true;
        }
        else
        {
            isSuccess = true;
        }
    }
}