@page "/teacher/login"
@using AcademyPortal.Services
@inject TeacherService TeacherService
@inject NavigationManager Navigation

<PageTitle>Teacher Login — AcademyPortal</PageTitle>

<div style="min-height:100vh; display:flex; align-items:center; justify-content:center; padding:40px 20px;">
    <div class="form-wrapper" style="width:100%; max-width:440px;">

        <div style="text-align:center; margin-bottom:28px;">
            <div style="font-size:48px; margin-bottom:12px;">👨‍🏫</div>
            <div class="form-title" style="text-align:center;">Teacher Login</div>
            <div class="form-subtitle" style="text-align:center;">Welcome back to AcademyPortal</div>
        </div>

        @if (isError)
        {
            <div class="alert-danger">❌ Invalid credentials or account not approved yet.</div>
        }

        <div class="form-group" style="margin-bottom:16px;">
            <label>Email Address</label>
            <input type="email" @bind="email" placeholder="teacher@academy.com" />
        </div>

        <div class="form-group" style="margin-bottom:16px;">
            <label>Password</label>
            <input type="password" @bind="password" placeholder="Enter your password" />
        </div>

        <button class="btn-rose" style="width:100%;" @onclick="HandleLogin">
            Login 🔐
        </button>

        <div style="text-align:center; margin-top:16px;">
            <div class="alert-danger" style="font-size:12px; padding:8px 12px;">
                ⚠️ Admin must approve your account before you can login.
            </div>
        </div>

        <div style="text-align:center; margin-top:16px;">
            <span style="color:var(--text-muted); font-size:13px;">Don't have an account? </span>
            <a href="/teacher/register" style="color:var(--rose-light); font-size:13px;">Register here</a>
        </div>

        <div style="text-align:center; margin-top:12px;">
            <a href="/" style="color:var(--text-muted); font-size:13px;">← Back to Home</a>
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private bool isError = false;

    private async Task HandleLogin()
    {
        isError = false;
        var teacher = await TeacherService.LoginAsync(email, password);
        if (teacher != null)
        {
            Navigation.NavigateTo($"/teacher/dashboard/{teacher.Id}");
        }
        else
        {
            isError = true;
        }
    }
}